{
  "name": "base-narrative-radar",
  "version": "1.0.0",
  "private": false,
  "description": "Evidence-first Base token due diligence skill: CA, website, X/Twitter, GitHub, product proof, and product-rug risk.",
  "type": "module",
  "scripts": {
    "base:discover": "BASE_DISCOVER_OUT_DIR=data/discovery node scripts/base_project_discover.mjs",
